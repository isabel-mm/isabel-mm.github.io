    <item>
      <title>Proyectos</title>
      <link>http://localhost:1313/es/projects/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/es/projects/</guid>
      <description>&lt;div class=&#34;section-intro&#34;&gt;&#xA;Proyectos de investigación en los que participo actualmente.&#xA;&lt;/div&gt;&#xA;&lt;div class=&#34;projects-gallery&#34;&gt;&#xA;&lt;div class=&#34;card&#34;&gt;&#xA;  &lt;div class=&#34;card__header&#34;&gt;&#xA;    &lt;h2 class=&#34;card__title&#34;&gt;TerlexWeb&lt;/h2&gt;&#xA;    &lt;span class=&#34;card__year&#34;&gt;2023–2027&lt;/span&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;p class=&#34;card__desc&#34;&gt;Aplicaciones de la lingüística digital al ámbito de la terminología: la creación de un léxico relacional bilingüe de los usos terminológicos de la semántica léxica.&lt;/p&gt;&#xA;  &lt;div class=&#34;card__tags&#34;&gt;&#xA;    &lt;span class=&#34;tag&#34;&gt;terminology&lt;/span&gt;&#xA;    &lt;span class=&#34;tag&#34;&gt;lexicology&lt;/span&gt;&#xA;    &lt;span class=&#34;tag&#34;&gt;digital humanities&lt;/span&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;p class=&#34;card__links&#34;&gt;&lt;a href=&#34;https://ila.uca.es/proyectos/&#34; target=&#34;_blank&#34; rel=&#34;noopener&#34;&gt;Más información →&lt;/a&gt;&lt;/p&gt;&#xA;  &lt;p class=&#34;card__links&#34;&gt;IP: Miguel Casas Gómez · Ministerio de Ciencia e Innovación&lt;/p&gt;&#xA;&lt;/div&gt;&#xA;&lt;div class=&#34;card&#34;&gt;&#xA;  &lt;div class=&#34;card__header&#34;&gt;&#xA;    &lt;h2 class=&#34;card__title&#34;&gt;ROBOT-TALK&lt;/h2&gt;&#xA;    &lt;span class=&#34;card__year&#34;&gt;2023–2026&lt;/span&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;p class=&#34;card__desc&#34;&gt;Reconocimiento del origen robótico de textos. Automatización de tareas y conocimiento lingüístico.&lt;/p&gt;&#xA;  &lt;div class=&#34;card__tags&#34;&gt;&#xA;    &lt;span class=&#34;tag&#34;&gt;stylometry&lt;/span&gt;&#xA;    &lt;span class=&#34;tag&#34;&gt;AI detection&lt;/span&gt;&#xA;    &lt;span class=&#34;tag&#34;&gt;NLP&lt;/span&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;p class=&#34;card__links&#34;&gt;&lt;a href=&#34;https://www.ucm.es/robottalk/&#34; target=&#34;_blank&#34; rel=&#34;noopener&#34;&gt;Más información →&lt;/a&gt;&lt;/p&gt;&#xA;  &lt;p class=&#34;card__links&#34;&gt;IPs: Ana María Fernández-Pampillón Cesteros &amp; Marianela Fernández Trinidad · Ministerio de Ciencia e Innovación&lt;/p&gt;</description>
